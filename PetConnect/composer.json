{
    "name": "petconnect/app",
    "description": "PetConnect — Pet adoption platform",
    "require": {
        "php": ">=8.1",
        "slim/slim": "^4.0",
        "slim/psr7": "^1.0",
        "slim/twig-view": "^3.0",
        "gabordemooij/redbean": "^5.7",
        "delight-im/auth": "^7.0",
        "symfony/translation": "^7.0",
        "robthree/twofactorauth": "^2.0",
        "vlucas/phpdotenv": "^5.0",
        "php-di/php-di": "^7.0",
        "phpmailer/phpmailer": "^6.9"
    },
    "autoload": {
        "psr-4": {
            "App\\": "Src/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
