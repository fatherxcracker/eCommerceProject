{% extends 'base.twig' %}
{% block title %}Manage Adoptions{% endblock %}

{% block content %}
<div class="admin-layout">
    <aside class="admin-sidebar">
        <h2>Admin Panel</h2>
        <nav>
            <a href="/admin">📊 Dashboard</a>
            <a href="/admin/pets">🐾 Manage Pets</a>
            <a href="/admin/users">👥 Users</a>
            <a href="/admin/adoptions">📋 Adoptions</a>
        </nav>
    </aside>

    <div class="admin-main">
        <h1>Adoption Requests</h1>
        <table class="data-table">
            <thead>
                <tr><th>Pet</th><th>Applicant</th><th>Submitted</th><th>Status</th><th>Actions</th></tr>
            </thead>
            <tbody>
                {% for req in requests %}
                <tr>
                    <td>{{ req.pet.name }}</td>
                    <td>{{ req.user.name }}</td>
                    <td>{{ req.submitted_at|date('M d, Y') }}</td>
                    <td><span class="badge badge--{{ req.status }}">{{ req.status|capitalize }}</span></td>
                    <td>
                        {% if req.status == 'pending' %}
                            <form action="/admin/adoptions/{{ req.id }}/approve" method="POST" style="display:inline">
                                <button class="btn btn--sm btn--success">✓ Approve</button>
                            </form>
                            <form action="/admin/adoptions/{{ req.id }}/reject" method="POST" style="display:inline">
                                <button class="btn btn--sm btn--danger">✗ Reject</button>
                            </form>
                        {% else %}
                            <em>—</em>
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
