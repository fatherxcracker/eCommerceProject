{% extends 'base.twig' %}
{% block title %}Adoption Request — {{ request.pet.name }}{% endblock %}

{% block content %}
<div class="status-page">
    <h1>Adoption Request</h1>

    <div class="status-card">
        <div class="status-card__pet">
            <img src="{{ request.pet.image ?? '/img/default-pet.jpg' }}" alt="{{ request.pet.name }}">
            <div>
                <h2>{{ request.pet.name }}</h2>
                <p>{{ request.pet.breed }} · {{ request.pet.age }} yrs</p>
            </div>
        </div>

        <dl class="status-details">
            <dt>Status</dt>
            <dd><span class="badge badge--{{ request.status }} badge--lg">{{ request.status|capitalize }}</span></dd>
            <dt>Submitted</dt>
            <dd>{{ request.submitted_at|date('F j, Y') }}</dd>
            {% if request.reviewed_at %}
                <dt>Reviewed</dt>
                <dd>{{ request.reviewed_at|date('F j, Y') }}</dd>
            {% endif %}
        </dl>

        {% if request.status == 'pending' %}
            <div class="status-notice status-notice--info">
                ⏳ Your request is under review. We'll update you soon!
            </div>
        {% elseif request.status == 'approved' %}
            <div class="status-notice status-notice--success">
                🎉 Congratulations! Your adoption has been approved. We'll contact you with next steps.
            </div>
        {% else %}
            <div class="status-notice status-notice--error">
                Unfortunately your request was not approved this time. <a href="/pets">Browse other pets</a>.
            </div>
        {% endif %}
    </div>

    <a href="/adoptions" class="btn btn--secondary">← All My Requests</a>
</div>
{% endblock %}
