{% extends 'base.twig' %}
{% block title %}Login{% endblock %}

{% block content %}
<div class="auth-page">
    <div class="auth-card">
        <h1>Welcome Back 🐾</h1>
        <p class="auth-card__sub">Log in to continue your adoption journey.</p>

        <form action="{{ base_path }}/login" method="POST" class="auth-form">
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" required autofocus>
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" required>
            </div>
            <button type="submit" class="btn btn--primary btn--full">Login</button>
        </form>

        <div class="auth-card__links">
            <a href="{{ base_path }}/reset-password">Forgot your password?</a>
            <span>·</span>
            <a href="{{ base_path }}/register">Create an account</a>
        </div>
    </div>
</div>
{% endblock %}
