{% extends 'base.twig' %}
{% block title %}{{ translations['reset.title']|default('Reset Password') }}{% endblock %}

{% block content %}
<div class="auth-page">
    <div class="auth-card">
        <h1>{{ translations['reset.title']|default('Reset Password') }}</h1>
        <form action="{{ base_path }}/reset-password" method="POST" class="auth-form">
            <div class="form-group">
                <label for="email">{{ translations['reset.your_email']|default('Your Email') }}</label>
                <input type="email" id="email" name="email" required autofocus>
            </div>
            <button type="submit" class="btn btn--primary btn--full">Send Reset Code</button>
        </form>
        <div class="auth-card__links"><a href="{{ base_path }}/login">{{ translations['reset.back_login']|default('← Back to Login') }}</a></div>
    </div>
</div>
{% endblock %}
