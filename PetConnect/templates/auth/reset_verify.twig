{% extends 'base.twig' %}
{% block title %}Enter Reset Code{% endblock %}

{% block content %}
<div class="auth-page">
    <div class="auth-card">
        <h1>🔐 Check Your Email</h1>
        <p class="auth-card__sub">We sent a 6-digit code to your email. Enter it below. The code expires in 10 minutes.</p>

        <form action="{{ base_path }}/reset-password/verify" method="POST" class="auth-form">
            <div class="form-group">
                <label for="code">Verification Code</label>
                <input type="text" id="code" name="code"
                       inputmode="numeric" pattern="[0-9]{6}"
                       maxlength="6" autofocus required
                       placeholder="000000">
            </div>
            <button type="submit" class="btn btn--primary btn--full">Verify Code</button>
        </form>

        <div class="auth-card__links">
            <a href="{{ base_path }}/reset-password">← Request a new code</a>
        </div>
    </div>
</div>
{% endblock %}
