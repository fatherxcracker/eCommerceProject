{% extends "base.twig" %}

{% block title %}Contact Us - PetConnect{% endblock %}

{% block content %}

<section class="contact-header">
    <h1>Contact Us</h1>
    <p>Have questions? We'd love to hear from you. Send us a message and we will respond as soon as possible.</p>
</section>

<section class="contact-page">

    <div class="contact-card">
        <h2>Send us a Message</h2>

        {% if success is defined %}
            <div class="contact-success">
                {{ success }}
            </div>
        {% endif %}

        {% if errors is defined %}
            <div class="contact-error">
                {% for error in errors %}
                    <p>{{ error }}</p>
                {% endfor %}
            </div>
        {% endif %}

        <form method="POST" action="{{ base_path }}/contact" class="contact-form">

            <div class="contact-row">
                <div class="form-group">
                    <label>Name *</label>
                    <input type="text" name="name" value="{{ old.name ?? '' }}">
                </div>

                <div class="form-group">
                    <label>Email *</label>
                    <input type="email" name="email" value="{{ old.email ?? '' }}">
                </div>
            </div>

            <div class="contact-row">
                <div class="form-group">
                    <label>Phone</label>
                    <input type="text" name="phone" value="{{ old.phone ?? '' }}">
                </div>

                <div class="form-group">
                    <label>Subject *</label>
                    <input type="text" name="subject" value="{{ old.subject ?? '' }}">
                </div>
            </div>

            <div class="form-group">
                <label>Message *</label>
                <textarea name="message" rows="5">{{ old.message ?? '' }}</textarea>
            </div>

            <button type="submit" class="btn btn--primary btn--full">
                Send Message
            </button>

            <p class="contact-note">
                We typically respond within 24 hours during business days.
            </p>
        </form>
    </div>

    <div class="contact-info-card">

        <div class="contact-info-item">
            <div class="contact-icon">✉</div>
            <div>
                <h3>Email</h3>
                <p>info@petconnect.com</p>
                <p>support@petconnect.com</p>
            </div>
        </div>

        <div class="contact-info-item">
            <div class="contact-icon">☎</div>
            <div>
                <h3>Phone</h3>
                <p>(555) 123-4567</p>
                <p>Monday - Friday: 9:00 AM - 6:00 PM</p>
            </div>
        </div>

        <div class="contact-info-item">
            <div class="contact-icon">📍</div>
            <div>
                <h3>Address</h3>
                <p>123 Pet Adoption Lane</p>
                <p>Montreal, QC</p>
                <p>Canada</p>
            </div>
        </div>

        <div class="contact-info-item">
            <div class="contact-icon">⏰</div>
            <div>
                <h3>Business Hours</h3>
                <p>Monday - Friday: 9:00 AM - 6:00 PM</p>
                <p>Saturday: 10:00 AM - 4:00 PM</p>
                <p>Sunday: Closed</p>
            </div>
        </div>

    </div>

</section>

{% endblock %}