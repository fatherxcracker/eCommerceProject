{% extends "base.twig" %}

{% block title %}{{ translations['contact.title']|default('Contact Us - PetConnect') }}{% endblock %}

{% block content %}

<section class="contact-header">
    <h1>{{ translations['contact.header_title']|default('Contact Us') }}</h1>
    <p>{{ translations['contact.header_subtitle']|default('Have questions? We\'d love to hear from you. Send us a message and we will respond as soon as possible.') }}</p>
</section>

<section class="contact-page">

    <div class="contact-card">
        <h2>{{ translations['contact.send_message']|default('Send us a Message') }}</h2>

        {% if success is defined %}
            <div class="contact-success">
                {{ translations['contact.success']|default(success) }}
            </div>
        {% endif %}

        {% if errors is defined %}
            <div class="contact-error">
                {% for error in errors %}
                    <p>{{ error }}</p>
                {% endfor %}
            </div>
        {% endif %}

        <form method="POST" action="{{ base_path }}/contact" class="contact-form">

            <div class="contact-row">
                <div class="form-group">
                    <label>{{ translations['contact.name']|default('Name') }} *</label>
                    <input type="text" name="name" value="{{ old.name ?? '' }}">
                </div>

                <div class="form-group">
                    <label>{{ translations['contact.email']|default('Email') }} *</label>
                    <input type="email" name="email" value="{{ old.email ?? '' }}">
                </div>
            </div>

            <div class="contact-row">
                <div class="form-group">
                    <label>{{ translations['contact.phone']|default('Phone') }}</label>
                    <input type="text" name="phone" value="{{ old.phone ?? '' }}">
                </div>

                <div class="form-group">
                    <label>{{ translations['contact.subject']|default('Subject') }} *</label>
                    <input type="text" name="subject" value="{{ old.subject ?? '' }}">
                </div>
            </div>

            <div class="form-group">
                <label>{{ translations['contact.message']|default('Message') }} *</label>
                <textarea name="message" rows="5">{{ old.message ?? '' }}</textarea>
            </div>

            <button type="submit" class="btn btn--primary btn--full">
                {{ translations['contact.send']|default('Send Message') }}
            </button>

            <p class="contact-note">
                {{ translations['contact.respond_note']|default('We typically respond within 24 hours during business days.') }}
            </p>
        </form>
    </div>

    <div class="contact-info-card">

        <div class="contact-info-item">
            <div class="contact-icon">✉</div>
            <div>
                <h3>{{ translations['contact.email_label']|default('Email') }}</h3>
                <p>info@petconnect.com</p>
                <p>support@petconnect.com</p>
            </div>
        </div>

        <div class="contact-info-item">
            <div class="contact-icon">☎</div>
            <div>
                <h3>{{ translations['contact.phone_label']|default('Phone') }}</h3>
                <p>(555) 123-4567</p>
                <p>{{ translations['contact.weekdays']|default('Monday - Friday: 9:00 AM - 6:00 PM') }}</p>
            </div>
        </div>

        <div class="contact-info-item">
            <div class="contact-icon">📍</div>
            <div>
                <h3>{{ translations['contact.address_label']|default('Address') }}</h3>
                <p>123 Pet Adoption Lane</p>
                <p>Montreal, QC</p>
                <p>Canada</p>
            </div>
        </div>

        <div class="contact-info-item">
            <div class="contact-icon">⏰</div>
            <div>
                <h3>{{ translations['contact.hours_title']|default('Business Hours') }}</h3>
                <p>{{ translations['contact.weekdays']|default('Monday - Friday: 9:00 AM - 6:00 PM') }}</p>
                <p>{{ translations['contact.saturday']|default('Saturday: 10:00 AM - 4:00 PM') }}</p>
                <p>{{ translations['contact.sunday']|default('Sunday: Closed') }}</p>
            </div>
        </div>

    </div>

</section>

{% endblock %}