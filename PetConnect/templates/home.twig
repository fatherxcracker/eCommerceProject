{% extends 'base.twig' %}

{% block title %}{{ translations['home.title']|default('PetConnect — Find Your Forever Friend') }}{% endblock %}

{% block content %}
<section class="hero-home">
    <div class="hero-home__text">
        <span class="eyebrow">{{ translations['home.adopt_slogan']|default('Adopt · Don\'t Shop') }}</span>
        <h1>{{ translations['home.hero_title']|default('Find Your<br><span class="hero-home__accent">Forever Friend.</span>')|raw }}</h1>
        <p class="hero-home__lead">{{ translations['home.subtitle']|default('Thousands of loving pets are waiting for a home. Browse adoptable dogs, cats, birds, and more — and start your journey today.') }}</p>
        <div class="hero-home__actions">
            <a href="{{ base_path }}/pets" class="btn btn--primary btn--lg">{{ translations['nav.browse_pets']|default('Browse Pets') }}</a>
            <a href="{{ base_path }}/about" class="btn btn--secondary btn--lg">{{ translations['nav.about']|default('Learn More') }}</a>
        </div>
    </div>
    <div class="hero-home__visual">
        <div class="hero-home__circle"></div>
        <img src="{{ base_path }}/Assets/images/PetConnect-Hero-Dog.jpg" alt="A happy dog" class="hero-home__image">
    </div>
</section>

<section class="stats-row">
    <div class="stat-pill"><span class="stat-pill__num">{{ stats.available }}</span><span class="stat-pill__label">{{ translations['home.stats_available']|default('Available Pets') }}</span></div>
    <div class="stat-pill"><span class="stat-pill__num">{{ stats.adopted }}</span><span class="stat-pill__label">{{ translations['home.stats_adopted']|default('Happy Adoptions') }}</span></div>
    <div class="stat-pill"><span class="stat-pill__num">{{ stats.categories }}</span><span class="stat-pill__label">{{ translations['home.stats_species']|default('Species') }}</span></div>
</section>

{% if featured %}
<section class="home-section">
    <div class="home-section__header">
        <h2>{{ translations['home.featured_pets']|default('Meet Some Friends') }}</h2>
        <a href="{{ base_path }}/pets" class="home-section__link">{{ translations['home.view_all']|default('View all pets') }} →</a>
    </div>
    <div class="pet-grid">
        {% for pet in featured %}
            <article class="pet-card">
                <a href="{{ base_path }}/pets/{{ pet.id }}">
                    <img src="{{ pet.image ? base_path ~ pet.image : base_path ~ '/Assets/img/default-pet.jpg' }}" alt="{{ pet.name }}" class="pet-card__img">
                    <div class="pet-card__body">
                        <span class="badge badge--{{ pet.status }}">{{ pet.status|capitalize }}</span>
                        <h3 class="pet-card__name">{{ pet.name }}</h3>
                        <p class="pet-card__meta">{{ pet.breed }} · {{ pet.age }} yr{% if pet.age != 1 %}s{% endif %}</p>
                        <p class="pet-card__location">📍 {{ pet.location }}</p>
                    </div>
                </a>
            </article>
        {% endfor %}
    </div>
</section>
{% endif %}

<section class="home-section">
    <h2 class="text-center">{{ translations['home.how_it_works']|default('How It Works') }}</h2>
    <div class="steps">
        <div class="step">
            <div class="step__icon">🔎</div>
            <h3>1. {{ translations['home.step1_title']|default('Browse') }}</h3>
            <p>{{ translations['home.step1_desc']|default('Explore profiles of pets in your area and filter by breed, age, or size.') }}</p>
        </div>
        <div class="step">
            <div class="step__icon">💌</div>
            <h3>2. {{ translations['home.step2_title']|default('Apply') }}</h3>
            <p>{{ translations['home.step2_desc']|default('Found a match? Send an adoption request directly through the site.') }}</p>
        </div>
        <div class="step">
            <div class="step__icon">🏠</div>
            <h3>3. {{ translations['home.step3_title']|default('Welcome Home') }}</h3>
            <p>{{ translations['home.step3_desc']|default('Get approved, meet your new friend, and welcome them home.') }}</p>
        </div>
    </div>
</section>

<section class="cta-banner">
    <h2>{{ translations['home.cta_title']|default('Ready to change a life?') }}</h2>
    <p>{{ translations['home.cta_subtitle']|default('A pet is waiting for you to choose them.') }}</p>
    <a href="{{ base_path }}/pets" class="btn btn--primary btn--lg">{{ translations['home.start_browsing']|default('Start Browsing') }}</a>
</section>
{% endblock %}
