<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PetConnect — Under Maintenance</title>
    <link rel="stylesheet" href="{{ base_path }}/Assets/styles.css">
    <script>
        (function() {
            const prefs = JSON.parse(localStorage.getItem('petconnect_prefs') || '{}');
            const theme = prefs.theme || 'system';
            const resolved = theme === 'system'
                ? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
                : theme;
            document.documentElement.setAttribute('data-theme', resolved);
        })();
    </script>
</head>
<body class="centered-page">
    <div class="maintenance-card">
        <div class="maintenance-card__logo">PetConnect</div>

        <img
            src="{{ base_path }}/Assets/images/PetConnect-Maintenance-Dog.png"
            alt="Maintenance dog"
            class="maintenance-card__img"
        >

        <span class="maintenance-card__status">Under Maintenance</span>

        <hr class="maintenance-card__divider">

        <h1>We'll be back soon!</h1>
        <p>Our team is working hard to improve PetConnect. We apologize for the inconvenience — please check back shortly.</p>
    </div>
</body>
</html>
