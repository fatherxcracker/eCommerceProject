<style>
.chat-fab {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--color-primary, #FF6B35);
    color: #fff;
    border: none;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(0,0,0,.2);
    font-size: 1.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    transition: transform .15s, opacity .15s;
}
.chat-fab:hover { transform: scale(1.08); }

.chat-window {
    position: fixed;
    bottom: 5rem;
    right: 1.5rem;
    width: 340px;
    max-height: 480px;
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0,0,0,.18);
    display: flex;
    flex-direction: column;
    z-index: 1000;
    overflow: hidden;
    transition: opacity .2s, transform .2s;
}
.chat-window.chat-hidden {
    opacity: 0;
    pointer-events: none;
    transform: translateY(12px);
}

.chat-header {
    background: var(--color-primary, #FF6B35);
    color: #fff;
    padding: .75rem 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-weight: 700;
    font-size: .95rem;
    flex-shrink: 0;
}
.chat-header__close {
    background: none;
    border: none;
    color: #fff;
    cursor: pointer;
    font-size: 1.2rem;
    line-height: 1;
    padding: 0;
}

.chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: .75rem 1rem;
    display: flex;
    flex-direction: column;
    gap: .5rem;
    font-size: .9rem;
}

.chat-bubble {
    max-width: 85%;
    padding: .5rem .75rem;
    border-radius: 12px;
    line-height: 1.5;
    word-break: break-word;
}
.chat-bubble--user {
    align-self: flex-end;
    background: var(--color-primary, #FF6B35);
    color: #fff;
    border-bottom-right-radius: 3px;
}
.chat-bubble--assistant {
    align-self: flex-start;
    background: #f5f5f5;
    color: #333;
    border-bottom-left-radius: 3px;
}
.chat-bubble--error {
    align-self: flex-start;
    background: #f8d7da;
    color: #721c24;
    border-bottom-left-radius: 3px;
}
.chat-bubble--typing {
    align-self: flex-start;
    background: #f5f5f5;
    color: #888;
    font-style: italic;
    border-bottom-left-radius: 3px;
}

.chat-form {
    display: flex;
    gap: .5rem;
    padding: .75rem;
    border-top: 1px solid #eee;
    flex-shrink: 0;
}
.chat-input {
    flex: 1;
    padding: .5rem .75rem;
    border: 1px solid #ddd;
    border-radius: 99px;
    font-size: .9rem;
    font-family: inherit;
}
.chat-input:focus { outline: 2px solid var(--color-primary, #FF6B35); border-color: transparent; }
.chat-send {
    padding: .5rem .9rem;
    background: var(--color-primary, #FF6B35);
    color: #fff;
    border: none;
    border-radius: 99px;
    cursor: pointer;
    font-size: .85rem;
    font-weight: 600;
    flex-shrink: 0;
    transition: opacity .15s;
}
.chat-send:disabled { opacity: .5; cursor: not-allowed; }

@media (max-width: 400px) {
    .chat-window { right: .5rem; left: .5rem; width: auto; }
}
</style>

<button class="chat-fab" id="chatFab" aria-label="Open chat assistant" title="Ask our AI assistant">
    🐾
</button>

<div class="chat-window chat-hidden" id="chatWindow" role="dialog" aria-label="PetConnect AI assistant">
    <div class="chat-header">
        <span>🐾 PetConnect Assistant</span>
        <button class="chat-header__close" id="chatClose" aria-label="Close chat">&times;</button>
    </div>
    <div class="chat-messages" id="chatMessages">
        <div class="chat-bubble chat-bubble--assistant">
            Hi{{ session.user_name is defined ? ', ' ~ session.user_name : '' }}! I'm your PetConnect assistant. Ask me anything about our pets, the adoption process, or how to navigate the site.
        </div>
    </div>
    <form class="chat-form" id="chatForm" autocomplete="off">
        <input
            type="text"
            class="chat-input"
            id="chatInput"
            placeholder="Ask a question…"
            maxlength="2000"
            required
            aria-label="Your message"
        >
        <button type="submit" class="chat-send" id="chatSend">Send</button>
    </form>
</div>

<script src="{{ base_path }}/Assets/chat.js"></script>
