<footer class="footer">
    <div class="footer__grid">
        <div class="footer__col">
            <div class="footer__brand">PetConnect</div>
            <p class="footer__tagline">Helping every pet find a forever home.</p>
        </div>

        <div class="footer__col">
            <h4 class="footer__heading">Explore</h4>
            <ul class="footer__links">
                <li><a href="{{ base_path }}/pets">Browse Pets</a></li>
                <li><a href="{{ base_path }}/about">About</a></li>
                <li><a href="{{ base_path }}/contact">Contact Us</a></li>
                <li><a href="{{ base_path }}/donate">♡ Donate</a></li
                <li><a href="{{ base_path }}/faq">FAQ</a></li>
            </ul>
        </div>

        <div class="footer__col">
            <h4 class="footer__heading">Account</h4>
            <ul class="footer__links">
                {% if session.user_id is defined and session.user_id %}
                    <li><a href="{{ base_path }}/profile">My Profile</a></li>
                    <li><a href="{{ base_path }}/adoptions">My Adoptions</a></li>
                {% else %}
                    <li><a href="{{ base_path }}/login">Login</a></li>
                    <li><a href="{{ base_path }}/register">Register</a></li>
                {% endif %}
            </ul>
        </div>
    </div>

    <div class="footer__bottom">
        &copy; {{ "now"|date("Y") }} PetConnect. All rights reserved.
    </div>
</footer>
